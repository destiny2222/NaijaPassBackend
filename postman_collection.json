      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "    pm.test(\"Token saved successfully\", function () {",
                  "        pm.expect(pm.collectionVariables.get(\"token\")).to.eql(jsonData.token);",
                  "    });",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Destiny Contractor\",\n  \"email\": \"destiny@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"user\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
